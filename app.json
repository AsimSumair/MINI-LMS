{
  "expo": {
    "name": "Mini LMS",
    "slug": "lms-mini",
    "scheme": "minilms",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#4F46E5"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.minilms.app",
      "infoPlist": {
        "UIBackgroundModes": [
          "remote-notification"
        ],
        "NSCameraUsageDescription": "Allow Mini LMS to access your camera for profile picture",
        "NSPhotoLibraryUsageDescription": "Allow Mini LMS to access your photos for profile picture"
      }
    },
    "android": {
      "package": "com.minilms.app",
      "permissions": [
        "android.permission.NOTIFICATIONS",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#4F46E5"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#4F46E5"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Mini LMS to access your photos to update your profile picture.",
          "cameraPermission": "Allow Mini LMS to access your camera to take a profile picture."
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9b7c2627-08d7-4aaa-8d02-216563376821"
      },
      "appEnv": "development",
      "apiBaseUrl": "https://api.freeapi.app"
    },
    "owner": "asimmirza"
  }
}